value":"from obspy.clients.fdsn import Client\nclient = Client(\"IRIS\")\n\neq = client.get_events(starttime=obspy.UTCDateTime(\"2023-01-01T00:00:00\"),\n                       endtime=obspy.UTCDateTime(\"2025-01-01T00:00:00\"),\n                       minmagnitude=7.5)\n\nprint(eq)\n# find the largest magnitude\nmags = [e.magnitudes[0].mag for e in eq]\nidx = np.argmax(mags)\neqmax = eq[idx]\nstarttime = obspy.UTCDateTime(eqmax.origins[0].time)  # Earthquake origin time\nendtime = starttime + 3*3600  # End time (3 hour after origin)","identifier":"dni_lx1uasyo-code","enumerator":"9","html_id":"dni-lx1uasyo-code","key":"dql8DHRAJg"},{"type":"outputs","id":"p2K4dIO5pcHhn_or1jU4x","children":[],"identifier":"dni_lx1uasyo-outputs","html_id":"dni-lx1uasyo-outputs","key":"ic6jNxTpvM"}],"identifier":"dni_lx1uasyo","label":"dNI_LX1uasYo","html_id":"dni-lx1uasyo","key":"Tvjz32MY1N"},{"type":"block","kind":"notebook-content","data":{"id":"sf6PFlRREcTF"},"children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"get station information","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"GOrxgc69VH"}],"identifier":"get-station-information","label":"get station information","html_id":"get-station-information","implicit":true,"key":"hcSejpWceW"}],"identifier":"sf6pflrrectf","label":"sf6PFlRREcTF","html_id":"sf6pflrrectf","key":"PB0eECkRP8"},{"type":"block","kind":"notebook-code","data":{"colab":{"base_uri":"https://localhost:8080/"},"id":"HCFJxZLoEdwo","outputId":"5de393bc-ae8a-4289-8b91-736797cbaf5e"},"children":[{"type":"code","lang":"python","executable":true,"value":"inv = client.get_stations(network=\"II\",station=\"*\",channel=\"BHZ\", starttime=starttime, endtime=endtime)\nprint(inv)","identifier":"hcfjxzloedwo-code","enumerator":"10","html_id":"hcfjxzloedwo-code","key":"wMNkRMB1OJ"},{"type":"outputs","id":"yI_E4tj0oUCZKHb1G5i8E","children":[],"identifier":"hcfjxzloedwo-outputs","html_id":"hcfjxzloedwo-outputs","key":"HQ3MQTMqHS"}],"identifier":"hcfjxzloedwo","label":"HCFJxZLoEdwo","html_id":"hcfjxzloedwo","key":"dibWE2gR3r"},{"type":"block","kind":"notebook-content","data":{"id":"F9iKAkyMbZ05"},"children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"download waveform data","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"CgQVzEV1oT"}],"identifier":"download-waveform-data","label":"download waveform data","html_id":"download-waveform-data","implicit":true,"key":"aG8JqddNb9"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Using Obspy, download the BHZ channel of the network of stations and append the data into a single array of traces.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"NjToo4jTDM"}],"key":"etXbcotvqz"}],"identifier":"f9ikakymbz05","label":"F9iKAkyMbZ05","html_id":"f9ikakymbz05","key":"Jhd8eblHHU"},{"type":"block","kind":"notebook-code","data":{"colab":{"base_uri":"https://localhost:8080/","height":686},"id":"317rWsJzbdV5","outputId":"b68a3b53-99a9-4203-8e9e-ce48c72e9e52"},"children":[{"type":"code","lang":"python","executable":true,"value":"st=[]#obspy.Trace()\nfor sta in inv[0]:\n  print(sta.code)\n  try:\n    st.append(client.get_waveforms(\"II\", sta.code, \"*\", \"BHZ\", starttime, endtime,attach_response=True))  # Get BHZ component data\n  except:\n    print(f\"Could not get data for station {sta.code}\")","identifier":"317rwsjzbdv5-code","enumerator":"11","html_id":"id-317rwsjzbdv5-code","key":"aTvayqy1br"},{"type":"outputs","id":"gD1e9V235ypthPXrpHXAx","children":[],"identifier":"317rwsjzbdv5-outputs","html_id":"id-317rwsjzbdv5-outputs","key":"qxpzN0KE5t"}],"identifier":"317rwsjzbdv5","label":"317rWsJzbdV5","html_id":"id-317rwsjzbdv5","key":"N18aU29aQt"},{"type":"block","kind":"notebook-content","data":{"id":"XNAS0SONatj3"},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"calculate angular distance","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"rhZXYbeYr6"}],"identifier":"calculate-angular-distance","label":"calculate angular distance","html_id":"calculate-angular-distance","implicit":true,"key":"nW4FarKgDI"}],"identifier":"xnas0sonatj3","label":"XNAS0SONatj3","html_id":"xnas0sonatj3","key":"ALzTtmhr4H"},{"type":"block","kind":"notebook-code","data":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LjRH9R-CavYS","outputId":"c735ba6d-b7cf-4b0e-cd81-16575f5bc658"},"children":[{"type":"code","lang":"python","executable":true,"value":"from obspy.geodetics import gps2dist_azimuth,locations2degrees\n\n\nevent_latitude = eqmax.origins[0].latitude  # Get event latitude from the first trace\nevent_longitude = eqmax.origins[0].longitude  # Get event longitude\n\ndistances = []\nang_distances = []\nfor tr in st:\n    for network in inv:\n        if network.code == tr[0].stats.network:\n            for station in network:\n                if station.code == tr[0].stats.station:\n                  station_latitude = station.latitude\n                  station_longitude = station.longitude\n    dist, az, baz = gps2dist_azimuth(event_latitude, event_longitude, station_latitude, station_longitude)\n    ang = locations2degrees(event_latitude, event_longitude, station_latitude, station_longitude)\n    # also get the angular distance\n\n    ang_distances.append(ang)\n    distances.append(dist / 1000)  # Convert distance to kilometers\n    print(f\"Distance between event and station {station.code}: {dist / 1000} km and angular distances: {ang} deg\")","identifier":"ljrh9r-cavys-code","enumerator":"12","html_id":"ljrh9r-cavys-code","key":"X26Bu927f5"},{"type":"outputs","id":"L6KnC19So31OMTzc8f0t6","children":[],"identifier":"ljrh9r-cavys-outputs","html_id":"ljrh9r-cavys-outputs","key":"WUO28Aarry"}],"identifier":"ljrh9r-cavys","label":"LjRH9R-CavYS","html_id":"ljrh9r-cavys","key":"znN7EZvLFB"},{"type":"block","kind":"notebook-content","data":{"id":"CV0nZrvLaxK_"},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"calculate travel times","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Ves2OMAQCg"}],"identifier":"calculate-travel-times","label":"calculate travel times","html_id":"calculate-travel-times","implicit":true,"key":"srLfaP6eEc"}],"identifier":"cv0nzrvlaxk_","label":"CV0nZrvLaxK_","html_id":"cv0nzrvlaxk","key":"vZy4hAi3AB"},{"type":"block","kind":"notebook-code","data":{"colab":{"base_uri":"https://localhost:8080/"},"id":"knM-TG6wazsE","outputId":"de804f88-ef87-4e15-cde8-f0342ddd2861"},"children":[{"type":"code","lang":"python","executable":true,"value":"model = TauPyModel(model=\"iasp91\")\ntravel_times = []\nfor dist in ang_distances:\n  arrivals = model.get_travel_times(source_depth_in_km=eqmax.origins[0].depth/1000, distance_in_degree=dist, phase_list=[\"P\"])\n  print(arrivals)\n  if len(arrivals):\n    travel_times.append(arrivals[0].time)\n  else:\n    travel_times.append(np.nan)","identifier":"knm-tg6wazse-code","enumerator":"13","html_id":"knm-tg6wazse-code","key":"wOJww1YC4x"},{"type":"outputs","id":"geGg7s9ksI-xjpm42r5cN","children":[],"identifier":"knm-tg6wazse-outputs","html_id":"knm-tg6wazse-outputs","key":"HRIwMrInXJ"}],"identifier":"knm-tg6wazse","label":"knM-TG6wazsE","html_id":"knm-tg6wazse","key":"WtJxuzYNbW"},{"type":"block","kind":"notebook-content","data":{"id":"r5Nq6WGea8DK"},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plot vertical seismogram","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tOMaVgjFaC"}],"identifier":"plot-vertical-seismogram","label":"Plot vertical seismogram","html_id":"plot-vertical-seismogram","implicit":true,"key":"tEjbFqmgUD"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Make a plot of the vertical seismograms as a function of","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"GoZtjIzyqB"}],"key":"mbAlkMONha"}],"identifier":"r5nq6wgea8dk","label":"r5Nq6WGea8DK","html_id":"r5nq6wgea8dk","key":"odspkkbNtw"},{"type":"block","kind":"notebook-code","data":{"colab":{"base_uri":"https://localhost:8080/","height":564},"id":"y06mejlta-Vg","outputId":"668a233e-2521-458d-da3f-1db584e4255e"},"children":[{"type":"code","lang":"python","executable":true,"value":"from obspy.signal.trigger import classic_sta_lta\nfig, ax = plt.subplots(figsize=(10, 6))\n\n\n  # STA/LTA parameters\nsta_window = 5 # Short-term window in seconds\nlta_window = 1000  # Long-term window in seconds\n\nfor i, tr in enumerate(st):\n  time_shift = 0#travel_times[i]  # Shift the time axis by the travel time\n  newtr = tr.copy()[0] # some stations may have several sensors at the same site, just pick the first one.\n  # filter and resample data\n  newtr.filter(\"bandpass\", freqmin=0.001, freqmax=1)\n  newtr.resample(10)\n  # normalize data\n  newtr.data/=np.max(np.abs(newtr.data))\n\n  # create sta/lta filter\n  # newtr.taper(0.05, type='cosine')\n\n\n  # Convert to sample points\n  sta_samples = int(sta_window / newtr.stats.delta)\n  lta_samples = int(lta_window / newtr.stats.delta)\n\n  # Compute STA/LTA function\n  impulsivity = classic_sta_lta(newtr.data, sta_samples, lta_samples)\n\n\n  ax.plot(impulsivity+ang_distances[i],newtr.times()/3600, \"k\")  # Plot the trace with an offset for visualization\n  # ax.plot(newtr.data+ang_distances[i],newtr.times()/3600, \"k\")  # Plot the trace with an offset for visualization\n\n  # plot markers for the predicted arrival times of P waves\n  ax.scatter(ang_distances[i], travel_times[i]/3600, marker=\"x\", color=\"r\")\n\nax.set_xlabel(\"Angular Distance (°)\")\nax.set_ylabel(\"Time (hour)\")\nax.set_title(\"Vertical Seismograms \")\nplt.show()","identifier":"y06mejlta-vg-code","enumerator":"14","html_id":"y06mejlta-vg-code","key":"vK04zjr4nm"},{"type":"outputs","id":"sXCsglcBhbDti0VqRqBAz","children":[],"identifier":"y06mejlta-vg-outputs","html_id":"y06mejlta-vg-outputs","key":"g0T4CJDkUB"}],"identifier":"y06mejlta-vg","label":"y06mejlta-Vg","html_id":"y06mejlta-vg","key":"lShKMzgdcR"}],"key":"umWjVxtP0u"},"references":{"cite":{"order":[],"data":{}}}}